# ── Frontend environment variables ──────────────────────────────────────────
# Copy to .env and .env.local for local development. Vite exposes VITE_*
# vars to the browser; anything else is only available at build time.

# Browser-visible API base. In dev this should stay relative so the Vite
# proxy avoids CORS and nested routes never resolve requests under /tickets.
VITE_API_BASE_URL=/tickora

# Backend target used only by the Vite dev-server proxy.
VITE_API_PROXY_TARGET=http://localhost:5100

# Dev server port
VITE_PORT=5173

# Keycloak OIDC
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=tickora
VITE_KEYCLOAK_CLIENT=tickora-spa
