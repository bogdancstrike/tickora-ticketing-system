# ── Application ──────────────────────────────────────────────────────────────
API_PORT=5100
DEV_MODE=true
LOG_LEVEL=DEBUG
SERVICE_NAME=tickora

# Process role: api | worker | sla_checker
ROLE=api

# CORS
ALLOWED_ORIGINS=http://localhost:5173

# ── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://tickora:tickora@localhost:5432/tickora
POSTGRES_USER=tickora
POSTGRES_PASSWORD=tickora
POSTGRES_DB=tickora
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Keycloak ─────────────────────────────────────────────────────────────────
KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=tickora
KEYCLOAK_API_CLIENT_ID=tickora-api
KEYCLOAK_API_CLIENT_SECRET=change-me
KEYCLOAK_SPA_CLIENT_ID=tickora-spa
KEYCLOAK_ISSUER=http://localhost:8080/realms/tickora
KEYCLOAK_AUDIENCE=tickora-api
JWKS_CACHE_TTL=3600
PRINCIPAL_CACHE_TTL=60

# Keycloak admin bootstrap (used by scripts/keycloak_bootstrap.py only)
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9094
KAFKA_TOPIC_FAST=tickora_fast
KAFKA_TOPIC_SLOW=tickora_slow
WORKER_NAME=tickora

# ── MinIO / Object storage ───────────────────────────────────────────────────
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio12345
S3_BUCKET_ATTACHMENTS=tickora-attachments
ATTACHMENT_MAX_SIZE_BYTES=26214400
ATTACHMENT_PRESIGNED_TTL=60

# ── Tracing ──────────────────────────────────────────────────────────────────
ENABLE_TRACING=true
OTLP_ENDPOINT=http://localhost:4317

# ── Email (worker) ───────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=tickora@example.com
